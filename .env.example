# Homebrew Postgres on Mac: use your macOS username (no password by default)
DATABASE_URL="postgresql://YOUR_MAC_USERNAME@localhost:5432/daily_job_hub"
DIRECT_URL="postgresql://YOUR_MAC_USERNAME@localhost:5432/daily_job_hub"
# Docker Postgres example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/daily_job_hub"
REDIS_URL="redis://localhost:6379"
# OpenAI is optional now; Gemini (free tier) powers embeddings + text generation
OPENAI_API_KEY=""
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
EMBEDDING_MODEL="models/gemini-embedding-001"
EMBEDDING_DIMENSIONS="768"
GEMINI_TEXT_MODEL="gemini-2.0-flash"
# Get a free key at https://console.groq.com/keys (powers AI text generation)
GROQ_API_KEY=""
GROQ_TEXT_MODEL="llama-3.3-70b-versatile"
# Optional: override company ATS boards to scrape (comma-separated slugs)
GREENHOUSE_COMPANIES=""
LEVER_COMPANIES=""
ASHBY_COMPANIES=""
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""
ADZUNA_COUNTRY="us"
ADZUNA_MAX_PAGES_PER_QUERY="3"
EMBEDDING_BACKFILL_LIMIT="200"
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3001"
NEXT_PUBLIC_API_BASE_URL="http://localhost:8000"
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_TRUST_HOST="true"
PYTHON_ENV="development"
SCRAPER_RUN_INTERVAL_MINUTES="30"
RATE_LIMIT_PER_MINUTE="120"
CORS_ORIGINS="http://localhost:3000"
